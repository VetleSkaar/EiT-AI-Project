# Backend Environment Variables

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Ollama Configuration
# Ollama should be running locally on your machine at port 11434.
#
# For manual (non-Docker) setup, use:
#   OLLAMA_API_URL=http://localhost:11434
#
# When running with Docker Compose, the compose file automatically sets
#   OLLAMA_API_URL=http://host.docker.internal:11434
# so the container reaches Ollama on your laptop without any changes here.
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Add your environment variables here
# DATABASE_URL=postgresql://user:password@localhost/dbname
# SECRET_KEY=your-secret-key-here
